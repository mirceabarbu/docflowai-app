# ══════════════════════════════════════════════════════════════════════════════
# DocFlowAI v2 — Variabile de mediu (Railway / .env local)
# Copiați acest fișier ca .env și completați valorile.
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────────────────────
# Portul pe care rulează serverul (setat automat de Railway)
PORT=3000

# URL-ul public al aplicației (fără slash la final)
# Necesar pentru generarea link-urilor de semnare trimise pe email
PUBLIC_BASE_URL=https://your-app.up.railway.app

# Origini permise pentru CORS (comma-separated, sau lăsați gol pentru *)
# Exemplu: https://docflow.institutie.ro,https://admin.institutie.ro
CORS_ORIGIN=

# ── Baza de date ───────────────────────────────────────────────────────────────
# Connection string PostgreSQL (furnizat automat de Railway PostgreSQL plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Autentificare JWT ──────────────────────────────────────────────────────────
# Secret pentru semnarea JWT — minim 32 caractere, aleator
# Generare: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_random_secret_min_32_chars

# ── Admin inițial ─────────────────────────────────────────────────────────────
# Parola pentru userul admin@docflowai.ro creat la prima pornire (dacă DB e goală)
# Ștergeți sau lăsați gol după prima autentificare
ADMIN_INIT_PASSWORD=

# Secret pentru endpoint-urile admin protejate suplimentar (opțional)
ADMIN_SECRET=

# ── Email (Resend.com) ─────────────────────────────────────────────────────────
# API key Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Adresa expeditor (trebuie verificată în Resend)
MAIL_FROM=DocFlowAI <noreply@institutie.ro>

# ── WhatsApp Business API (Meta) ───────────────────────────────────────────────
# ID-ul numărului de telefon din Meta Business Manager
WA_PHONE_NUMBER_ID=

# Token permanent din Meta Business Manager > System Users
WA_ACCESS_TOKEN=

# Numele template-urilor aprobate în Meta Business Manager (UTILITY)
# Template variabile: [1]=numeSemnatar [2]=numeDocument
WA_TEMPLATE_SIGN=docflow_sign_request

# Template variabile: [1]=numeDocument
WA_TEMPLATE_COMPLETE=docflow_completed

# Template variabile: [1]=numeDocument [2]=numeRefuzant [3]=motiv
WA_TEMPLATE_REFUSED=docflow_refused

# Codul de limbă al template-urilor (ro sau en_US)
WA_TEMPLATE_LANG=ro

# Prefix internațional implicit pentru numere naționale (ex: 40 pentru România)
WA_DEFAULT_COUNTRY_PREFIX=40

# ── Google Drive (arhivare PDF-uri) ───────────────────────────────────────────
# JSON-ul Service Account Google (toată valoarea pe o singură linie sau base64)
# Creați în Google Cloud Console > IAM > Service Accounts
# Acordați acces Drive la folder-ul dorit
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"..."}

# ID-ul folder-ului Google Drive unde se arhivează PDF-urile semnate
# Găsiți în URL-ul folder-ului: drive.google.com/drive/folders/FOLDER_ID
GOOGLE_DRIVE_FOLDER_ID=

# ── Push Notifications Web (VAPID) ────────────────────────────────────────────
# Generare chei VAPID:
#   npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Subiect VAPID — mailto: sau URL-ul aplicației
VAPID_SUBJECT=mailto:admin@institutie.ro
